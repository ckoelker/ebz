# ── Projekt-.gitignore (ebz/) — gilt rekursiv für showcase/ + Planungsordner ──

# Wegwerf-/Generier-Outputs (unversioniert) — z.B. Architektur-MD+PDF aus ARCHITEKTUR-GENERIERUNG.md
/tmp/

# Secrets / lokale Env (NICHT committen) — .env.example und frontend/.env.development bleiben versioniert
.env
.env.local
*.local
!.env.example
**/.dlt/secrets.toml

# Node / pnpm  (pnpm-lock.yaml + pnpm-workspace.yaml WERDEN committed)
node_modules/
dist/
.pnpm-store/
npm-debug.log*
pnpm-debug.log*
*.log

# Vendure-Artefakte
.vendure/
vendure.sqlite
admin-ui/
static/assets/
static/email/test-emails/

# GraphQL-Codegen-Ausgabe (generiert)
**/src/gql/

# Java / Quarkus (M1 — showcase/integration)
target/
.quarkus/
*.class

# Python / dlt + dbt (M2/M3 — showcase/dlt, showcase/dbt)
.venv/
venv/
__pycache__/
*.py[cod]
**/dbt/target/
**/dbt/logs/
**/dbt/dbt_packages/
**/dbt/.user.yml

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
.claude/settings.local.json

# Prozessdoku — generierte BPMN (aus den OTel-Spans erzeugt: bash showcase/prozessdoku/build.sh)
showcase/docs/bpmn/
showcase/prozessdoku/out/

# LMS-Seed-/Testdaten — heruntergeladene SCORM-Pakete (nicht committen, nur lokal/dev)
testdata/
**/testdata/

# OpenOLAT-Build-Artefakte (heruntergeladen via showcase/openolat/fetch-artifacts.sh; nicht committen)
showcase/openolat/openolat_*.war
showcase/openolat/postgresql.jar
