{
  "name": "vendure",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev:server": "ts-node ./src/index.ts",
    "dev:worker": "ts-node ./src/index-worker.ts",
    "dev:dashboard": "vite --clearScreen false",
    "dev": "concurrently --kill-others \"pnpm dev:server\" \"pnpm dev:worker\" \"pnpm dev:dashboard\"",
    "build": "tsc",
    "build:dashboard": "vite build",
    "start:server": "node ./dist/index.js",
    "start:worker": "node ./dist/index-worker.js",
    "start": "concurrently \"pnpm start:server\" \"pnpm start:worker\""
  },
  "dependencies": {
    "@pinelab/vendure-plugin-stripe-subscription": "^2.10.0",
    "@vendure/asset-server-plugin": "3.6.4",
    "@vendure/core": "3.6.4",
    "@vendure/dashboard": "3.6.4",
    "@vendure/email-plugin": "3.6.4",
    "@vendure/graphiql-plugin": "3.6.4",
    "dotenv": "17.4.2",
    "jose": "^6.2.3",
    "oidc-client-ts": "3.5.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@vendure/cli": "3.6.4",
    "concurrently": "10.0.3",
    "ts-node": "10.9.2",
    "typescript": "5.8.2",
    "vite": "7.3.5"
  }
}
