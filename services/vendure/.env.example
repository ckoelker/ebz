APP_ENV=dev
PORT=3000
COOKIE_SECRET=change-me-to-a-random-string
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin

# PostgreSQL connection (local dev points at the Dockerized DB on host port 6543)
DB_HOST=localhost
DB_PORT=6543
DB_NAME=vendure
DB_USERNAME=vendure
DB_PASSWORD=vendure

# Stripe-Subscription-Plugin (M3)
VENDURE_HOST=http://localhost:3000

# Keycloak SSO (lokal: Issuer = JWKS = localhost:8088; im Container: JWKS = http://keycloak:8080)
KEYCLOAK_ISSUER_CUSTOMERS=http://localhost:8088/realms/ebz-customers
KEYCLOAK_JWKS_CUSTOMERS=http://localhost:8088/realms/ebz-customers/protocol/openid-connect/certs
KEYCLOAK_ISSUER_STAFF=http://localhost:8088/realms/ebz-staff
KEYCLOAK_JWKS_STAFF=http://localhost:8088/realms/ebz-staff/protocol/openid-connect/certs
