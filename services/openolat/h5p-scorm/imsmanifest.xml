<?xml version="1.0" encoding="UTF-8"?>
<!-- Minimaler SCORM-1.2-Manifest, der die H5P-HTML5-Wiedergabe (index.html) als einzelnen SCO
     startet. OpenOLAT importiert das gesamte Zip als FileResource.SCORMCP und liefert index.html
     im SCORM-Player-iframe aus. Tracking (LMSInitialize etc.) wird hier bewusst nicht genutzt —
     der Showcase will die H5P-Inhalte zeigen, nicht Scores zurückmelden. -->
<manifest identifier="EBZ-H5P-CP" version="1.2"
  xmlns="http://www.imsproject.org/xsd/imscp_rootv1p1p2"
  xmlns:adlcp="http://www.adlnet.org/xsd/adlcp_rootv1p2"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.imsproject.org/xsd/imscp_rootv1p1p2 imscp_rootv1p1p2.xsd http://www.adlnet.org/xsd/adlcp_rootv1p2 adlcp_rootv1p2.xsd">
  <metadata><schema>ADL SCORM</schema><schemaversion>1.2</schemaversion></metadata>
  <organizations default="ORG">
    <organization identifier="ORG">
      <title>EBZ H5P Showcase</title>
      <item identifier="ITEM1" identifierref="RES1"><title>Course Presentation (H5P)</title></item>
    </organization>
  </organizations>
  <resources>
    <resource identifier="RES1" type="webcontent" adlcp:scormtype="sco" href="index.html">
      <file href="index.html"/>
    </resource>
  </resources>
</manifest>
