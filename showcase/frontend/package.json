{
  "name": "ebz-shop-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "description": "EBZ Showcase — Vue-3-Storefront gegen Vendure Shop-API (M5)",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch"
  },
  "dependencies": {
    "@primeuix/themes": "2.0.3",
    "@urql/vue": "^1.4.0",
    "graphql": "^16.9.0",
    "oidc-client-ts": "3.5.0",
    "pinia": "3.0.4",
    "primeicons": "7.0.0",
    "primevue": "4.5.5",
    "vue": "3.5.38",
    "vue-router": "5.1.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.1.2",
    "@graphql-codegen/client-preset": "^6.0.1",
    "@types/node": "^22.19.21",
    "@vitejs/plugin-vue": "6.0.7",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vue-tsc": "3.3.4"
  }
}
