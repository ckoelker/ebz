{
  "realm": "ebz-staff",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "staff",
        "description": "EBZ Mitarbeiter:in"
      },
      {
        "name": "controlling",
        "description": "Darf Controlling/Unternehmens-GuV sehen (L23: Gehälter in Gemeinkosten)"
      },
      {
        "name": "katalog-pflege",
        "description": "Darf Bildungsangebote (MDM-Katalog) anlegen/ändern/archivieren (P1.2 RBAC, §11.5)"
      },
      {
        "name": "rechnung-pflege",
        "description": "Darf Debitoren/Anmeldungen pflegen und Rechnungen erzeugen/ausstellen/stornieren (R1 RBAC)"
      },
      {
        "name": "crm-lesen",
        "description": "Darf den CRM-Kundenstamm (Personen/Organisationen) lesen"
      },
      {
        "name": "crm-pflege",
        "description": "Darf CRM-Stammdaten/Mitgliedschaften/Kontaktpunkte anlegen/ändern"
      },
      {
        "name": "crm-datenschutz",
        "description": "Darf Betroffenenrechte ausüben (Recht auf Vergessen, Anonymisierung)"
      },
      {
        "name": "mcp-zugriff",
        "description": "Darf den hauseigenen MCP-Server (/mcp) aufrufen (Agent-/M2M-Zugriff, Scope)"
      }
    ]
  },
  "groups": [
    {
      "name": "controlling",
      "path": "/controlling",
      "realmRoles": [
        "controlling"
      ]
    }
  ],
  "clients": [
    {
      "clientId": "mdm-cockpit",
      "name": "MDM-Cockpit (Bildungsangebote)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "rootUrl": "http://localhost:5174",
      "redirectUris": [
        "http://localhost:5174/*"
      ],
      "webOrigins": [
        "http://localhost:5174",
        "+"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5174/*"
      }
    },
    {
      "clientId": "vendure-dashboard",
      "name": "Vendure Dashboard (Shop-Admin)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "rootUrl": "http://localhost:3000",
      "redirectUris": [
        "http://localhost:3000/dashboard/*",
        "http://localhost:5173/dashboard/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:5173",
        "+"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/dashboard/*"
      }
    },
    {
      "clientId": "staff-frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "rootUrl": "http://localhost:5173",
      "redirectUris": [
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "+"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/*"
      }
    },
    {
      "clientId": "lightdash",
      "name": "Lightdash BI (Controlling)",
      "enabled": true,
      "publicClient": false,
      "secret": "lightdash-dev-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:8084/*"
      ],
      "webOrigins": [
        "http://localhost:8084",
        "+"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8084/*"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups"
          }
        }
      ]
    },
    {
      "clientId": "storefront-service",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "storefront-service-secret",
      "protocol": "openid-connect"
    },
    {
      "clientId": "mcp-client",
      "name": "MCP-Client (Agent/M2M-Zugriff auf den Aktivitätslog-MCP-Server)",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "secret": "mcp-client-secret",
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "service-account-mcp-client",
      "enabled": true,
      "serviceAccountClientId": "mcp-client",
      "realmRoles": [
        "mcp-zugriff"
      ]
    },
    {
      "username": "staff",
      "email": "staff@ebz.de",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Stefan",
      "lastName": "Mitarbeiter",
      "credentials": [
        {
          "type": "password",
          "value": "staff",
          "temporary": false
        }
      ],
      "realmRoles": [
        "staff",
        "katalog-pflege",
        "rechnung-pflege",
        "crm-lesen",
        "crm-pflege",
        "crm-datenschutz"
      ],
      "groups": [
        "/controlling"
      ]
    },
    {
      "username": "staff2",
      "email": "staff2@ebz.de",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Sabine",
      "lastName": "Sachbearbeitung",
      "credentials": [
        {
          "type": "password",
          "value": "staff2",
          "temporary": false
        }
      ],
      "realmRoles": [
        "staff",
        "rechnung-pflege",
        "crm-lesen",
        "crm-pflege"
      ]
    },
    {
      "username": "service-account-storefront-service",
      "enabled": true,
      "serviceAccountClientId": "storefront-service",
      "realmRoles": [
        "katalog-pflege"
      ]
    }
  ]
}