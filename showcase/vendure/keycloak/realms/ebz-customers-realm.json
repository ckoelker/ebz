{
  "realm": "ebz-customers",
  "enabled": true,
  "organizationsEnabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "verifyEmail": true,
  "resetPasswordAllowed": true,
  "loginTheme": "ebz",
  "smtpServer": {
    "host": "mailpit",
    "port": "1025",
    "from": "no-reply@ebz-training.de",
    "fromDisplayName": "EBZ Akademie",
    "ssl": "false",
    "starttls": "false",
    "auth": "false"
  },
  "identityProviders": [
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": true,
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "${GOOGLE_CLIENT_ID:google-client-id-nicht-konfiguriert}",
        "clientSecret": "${GOOGLE_CLIENT_SECRET:google-client-secret-nicht-konfiguriert}",
        "useJwksUrl": "true",
        "syncMode": "IMPORT",
        "defaultScope": "openid profile email"
      }
    }
  ],
  "clients": [
    {
      "clientId": "shop-frontend",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "rootUrl": "http://localhost:5173",
      "redirectUris": [
        "http://localhost:3001/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "+",
        "http://localhost:3001",
        "http://localhost:5173"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3001/*##http://localhost:5173/*"
      }
    },
    {
      "clientId": "ebz-portal",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "rootUrl": "http://localhost:5175",
      "redirectUris": [
        "http://localhost:5175/*"
      ],
      "webOrigins": [
        "http://localhost:5175",
        "+"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5175/*"
      }
    },
    {
      "clientId": "openolat",
      "enabled": true,
      "publicClient": false,
      "secret": "openolat-dev-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "rootUrl": "http://localhost:8089",
      "redirectUris": [
        "http://localhost:8089/*"
      ],
      "webOrigins": [
        "http://localhost:8089",
        "+"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8089/*"
      }
    }
  ],
  "users": [
    {
      "username": "customer",
      "email": "customer@ebz.de",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Carla",
      "lastName": "Kundin",
      "credentials": [
        {
          "type": "password",
          "value": "customer",
          "temporary": false
        }
      ]
    }
  ]
}