      },
      "defaultClientScopes": ["web-origins", "acr", "roles", "profile", "basic", "email", "organization", "mandant"],
      "optionalClientScopes": ["address", "phone", "offline_access", "microprofile-jwt"]
    },
    {
      "clientId": "openolat",
      "enabled": true,
      "publicClient": false,
      "secret": "openolat-dev-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "rootUrl": "http://localhost:8089",
      "redirectUris": [
        "http://localhost:8089/*"
      ],
      "webOrigins": [
        "http://localhost:8089",
        "+"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8089/*"
      },
      "defaultClientScopes": ["web-origins", "acr", "roles", "profile", "basic", "email", "organization", "mandant"],
      "optionalClientScopes": ["address", "phone", "offline_access", "microprofile-jwt"]
    }
