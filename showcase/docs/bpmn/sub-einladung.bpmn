<?xml version="1.0" encoding="UTF-8"?>
<!-- swimlane-laidout: eigener Layouter (showcase/prozessdoku/generate.py) -->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://ebz/prozessdoku">
  <bpmn:collaboration id="collab_sub-einladung">
    <bpmn:participant id="participant_sub-einladung" name="Login-Einladung" processRef="process_sub-einladung"/>
  </bpmn:collaboration>
  <bpmn:process id="process_sub-einladung" isExecutable="false">
    <bpmn:laneSet id="laneset_sub-einladung">
      <bpmn:lane id="lane_sub-einladung_firma_ansprechpartner" name="Firma (Ansprechpartner)">
        <bpmn:flowNodeRef>end</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_login_und_konto_claim</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_sub-einladung_ebz_sachbearbeitung" name="EBZ-Sachbearbeitung">
        <bpmn:flowNodeRef>task_login_einladung_ausloesen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>start</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_sub-einladung_system" name="System">
        <bpmn:flowNodeRef>task_einladungsmail_senden</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_login_provisionieren</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:task id="task_einladungsmail_senden" name="Einladungsmail senden · Mail">
			<bpmn:incoming>flow_task_login_provisionieren__task_einladungsmail_senden</bpmn:incoming>
			<bpmn:outgoing>flow_task_einladungsmail_senden__task_login_und_konto_claim</bpmn:outgoing>
		</bpmn:task>
		<bpmn:task id="task_login_einladung_ausloesen" name="Login-Einladung auslösen · MDM-Cockpit">
			<bpmn:incoming>flow_start__task_login_einladung_ausloesen</bpmn:incoming>
			<bpmn:outgoing>flow_task_login_einladung_ausloesen__task_login_provisionieren</bpmn:outgoing>
		</bpmn:task>
		<bpmn:endEvent id="end" name="end">
			<bpmn:incoming>flow_task_login_und_konto_claim__end</bpmn:incoming>
		</bpmn:endEvent>
		<bpmn:task id="task_login_provisionieren" name="Login provisionieren · Keycloak">
			<bpmn:incoming>flow_task_login_einladung_ausloesen__task_login_provisionieren</bpmn:incoming>
			<bpmn:outgoing>flow_task_login_provisionieren__task_einladungsmail_senden</bpmn:outgoing>
		</bpmn:task>
		<bpmn:task id="task_login_und_konto_claim" name="Login &amp; Konto-Claim · Keycloak">
			<bpmn:incoming>flow_task_einladungsmail_senden__task_login_und_konto_claim</bpmn:incoming>
			<bpmn:outgoing>flow_task_login_und_konto_claim__end</bpmn:outgoing>
		</bpmn:task>
		<bpmn:startEvent id="start" isInterrupting="true" name="start" parallelMultiple="false">
			<bpmn:outgoing>flow_start__task_login_einladung_ausloesen</bpmn:outgoing>
		</bpmn:startEvent>
		<bpmn:sequenceFlow id="flow_task_login_einladung_ausloesen__task_login_provisionieren" name="" sourceRef="task_login_einladung_ausloesen" targetRef="task_login_provisionieren"/>
		<bpmn:sequenceFlow id="flow_task_einladungsmail_senden__task_login_und_konto_claim" name="" sourceRef="task_einladungsmail_senden" targetRef="task_login_und_konto_claim"/>
		<bpmn:sequenceFlow id="flow_task_login_provisionieren__task_einladungsmail_senden" name="" sourceRef="task_login_provisionieren" targetRef="task_einladungsmail_senden"/>
		<bpmn:sequenceFlow id="flow_start__task_login_einladung_ausloesen" name="" sourceRef="start" targetRef="task_login_einladung_ausloesen"/>
		<bpmn:sequenceFlow id="flow_task_login_und_konto_claim__end" name="" sourceRef="task_login_und_konto_claim" targetRef="end"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="diagram_sub-einladung">
    <bpmndi:BPMNPlane id="plane_sub-einladung" bpmnElement="collab_sub-einladung">
      <bpmndi:BPMNShape id="participant_sub-einladung_di" bpmnElement="participant_sub-einladung" isHorizontal="true">
        <omgdc:Bounds x="0" y="0" width="1140" height="330"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_sub-einladung_firma_ansprechpartner_di" bpmnElement="lane_sub-einladung_firma_ansprechpartner" isHorizontal="true">
        <omgdc:Bounds x="30" y="0" width="1110" height="110"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_sub-einladung_ebz_sachbearbeitung_di" bpmnElement="lane_sub-einladung_ebz_sachbearbeitung" isHorizontal="true">
        <omgdc:Bounds x="30" y="110" width="1110" height="110"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_sub-einladung_system_di" bpmnElement="lane_sub-einladung_system" isHorizontal="true">
        <omgdc:Bounds x="30" y="220" width="1110" height="110"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_einladungsmail_senden_di" bpmnElement="task_einladungsmail_senden">
        <omgdc:Bounds x="640" y="235" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_login_einladung_ausloesen_di" bpmnElement="task_login_einladung_ausloesen">
        <omgdc:Bounds x="280" y="125" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_di" bpmnElement="end">
        <omgdc:Bounds x="1000" y="37" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_login_provisionieren_di" bpmnElement="task_login_provisionieren">
        <omgdc:Bounds x="460" y="235" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_login_und_konto_claim_di" bpmnElement="task_login_und_konto_claim">
        <omgdc:Bounds x="820" y="15" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <omgdc:Bounds x="100" y="147" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="flow_task_login_einladung_ausloesen__task_login_provisionieren_di" bpmnElement="flow_task_login_einladung_ausloesen__task_login_provisionieren">
        <omgdi:waypoint x="380" y="165"/>
        <omgdi:waypoint x="420" y="165"/>
        <omgdi:waypoint x="420" y="275"/>
        <omgdi:waypoint x="460" y="275"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_task_einladungsmail_senden__task_login_und_konto_claim_di" bpmnElement="flow_task_einladungsmail_senden__task_login_und_konto_claim">
        <omgdi:waypoint x="740" y="275"/>
        <omgdi:waypoint x="780" y="275"/>
        <omgdi:waypoint x="780" y="55"/>
        <omgdi:waypoint x="820" y="55"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_task_login_provisionieren__task_einladungsmail_senden_di" bpmnElement="flow_task_login_provisionieren__task_einladungsmail_senden">
        <omgdi:waypoint x="560" y="275"/>
        <omgdi:waypoint x="600" y="275"/>
        <omgdi:waypoint x="600" y="275"/>
        <omgdi:waypoint x="640" y="275"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_start__task_login_einladung_ausloesen_di" bpmnElement="flow_start__task_login_einladung_ausloesen">
        <omgdi:waypoint x="136" y="165"/>
        <omgdi:waypoint x="208" y="165"/>
        <omgdi:waypoint x="208" y="165"/>
        <omgdi:waypoint x="280" y="165"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_task_login_und_konto_claim__end_di" bpmnElement="flow_task_login_und_konto_claim__end">
        <omgdi:waypoint x="920" y="55"/>
        <omgdi:waypoint x="960" y="55"/>
        <omgdi:waypoint x="960" y="55"/>
        <omgdi:waypoint x="1000" y="55"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
