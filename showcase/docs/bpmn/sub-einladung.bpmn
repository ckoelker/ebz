      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_login_provisionieren_di" bpmnElement="task_login_provisionieren">
        <omgdc:Bounds x="325" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_einladungsmail_senden_di" bpmnElement="task_einladungsmail_senden">
        <omgdc:Bounds x="475" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_login_und_konto_claim_di" bpmnElement="task_login_und_konto_claim">
        <omgdc:Bounds x="625" y="30" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_di" bpmnElement="end">
        <omgdc:Bounds x="807" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="flow_start__task_login_einladung_ausloesen_di" bpmnElement="flow_start__task_login_einladung_ausloesen">
        <omgdi:waypoint x="93" y="70" />
        <omgdi:waypoint x="175" y="70" />
      </bpmndi:BPMNEdge>
