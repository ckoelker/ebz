        <omgdi:waypoint x="275" y="70" />
        <omgdi:waypoint x="325" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_task_login_provisionieren__task_einladungsmail_senden_di" bpmnElement="flow_task_login_provisionieren__task_einladungsmail_senden">
        <omgdi:waypoint x="425" y="70" />
        <omgdi:waypoint x="475" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_task_einladungsmail_senden__task_login_und_konto_claim_di" bpmnElement="flow_task_einladungsmail_senden__task_login_und_konto_claim">
        <omgdi:waypoint x="575" y="70" />
        <omgdi:waypoint x="625" y="70" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_task_login_und_konto_claim__end_di" bpmnElement="flow_task_login_und_konto_claim__end">
