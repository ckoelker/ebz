<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" targetNamespace="http://www.signavio.com/bpmn20">
  <bpmn:process id="process_sub-einladung" processType="None" isClosed="false" isExecutable="false">
    <bpmn:task id="task_login_provisionieren" name="Login provisionieren — System · Keycloak">
      <bpmn:incoming>flow_task_login_einladung_ausloesen__task_login_provisionieren</bpmn:incoming>
      <bpmn:outgoing>flow_task_login_provisionieren__task_einladungsmail_senden</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_einladungsmail_senden" name="Einladungsmail senden — System · Mail">
      <bpmn:incoming>flow_task_login_provisionieren__task_einladungsmail_senden</bpmn:incoming>
      <bpmn:outgoing>flow_task_einladungsmail_senden__task_login_und_konto_claim</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_login_einladung_ausloesen" name="Login-Einladung auslösen — EBZ-Sachbearbeitung · MDM-Cockpit">
      <bpmn:incoming>flow_start__task_login_einladung_ausloesen</bpmn:incoming>
      <bpmn:outgoing>flow_task_login_einladung_ausloesen__task_login_provisionieren</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_login_und_konto_claim" name="Login &#38; Konto-Claim">
      <bpmn:incoming>flow_task_einladungsmail_senden__task_login_und_konto_claim</bpmn:incoming>
      <bpmn:outgoing>flow_task_login_und_konto_claim__end</bpmn:outgoing>
    </bpmn:task>
    <bpmn:startEvent id="start" name="start">
      <bpmn:outgoing>flow_start__task_login_einladung_ausloesen</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="end" name="end">
      <bpmn:incoming>flow_task_login_und_konto_claim__end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_start__task_login_einladung_ausloesen" name="" sourceRef="start" targetRef="task_login_einladung_ausloesen" />
    <bpmn:sequenceFlow id="flow_task_login_einladung_ausloesen__task_login_provisionieren" name="" sourceRef="task_login_einladung_ausloesen" targetRef="task_login_provisionieren" />
    <bpmn:sequenceFlow id="flow_task_login_und_konto_claim__end" name="" sourceRef="task_login_und_konto_claim" targetRef="end" />
    <bpmn:sequenceFlow id="flow_task_login_provisionieren__task_einladungsmail_senden" name="" sourceRef="task_login_provisionieren" targetRef="task_einladungsmail_senden" />
    <bpmn:sequenceFlow id="flow_task_einladungsmail_senden__task_login_und_konto_claim" name="" sourceRef="task_einladungsmail_senden" targetRef="task_login_und_konto_claim" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_process_sub-einladung">
    <bpmndi:BPMNPlane id="BPMNPlane_process_sub-einladung" bpmnElement="process_sub-einladung">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <omgdc:Bounds x="57" y="52" width="36" height="36" />
      </bpmndi:BPMNShape>
