    <bpmn:startEvent id="start" name="Start"/><bpmn:parallelGateway id="gw_split" gatewayDirection="Diverging"/><bpmn:task id="task_azubi_nach_webuntis_uebertragen" name="Azubi nach WebUntis übertragen · WebUntis"/><bpmn:task id="task_azubi_nach_suite8_uebertragen" name="Azubi nach Suite8 übertragen · Suite8"/><bpmn:parallelGateway id="gw_join" gatewayDirection="Converging"/><bpmn:endEvent id="end" name="Ende"/><bpmn:sequenceFlow id="flow_start__gw_split" sourceRef="start" targetRef="gw_split"/><bpmn:sequenceFlow id="flow_gw_split__task_azubi_nach_webuntis_uebertragen" sourceRef="gw_split" targetRef="task_azubi_nach_webuntis_uebertragen"/><bpmn:sequenceFlow id="flow_task_azubi_nach_webuntis_uebertragen__gw_join" sourceRef="task_azubi_nach_webuntis_uebertragen" targetRef="gw_join"/><bpmn:sequenceFlow id="flow_gw_split__task_azubi_nach_suite8_uebertragen" sourceRef="gw_split" targetRef="task_azubi_nach_suite8_uebertragen"/><bpmn:sequenceFlow id="flow_task_azubi_nach_suite8_uebertragen__gw_join" sourceRef="task_azubi_nach_suite8_uebertragen" targetRef="gw_join"/><bpmn:sequenceFlow id="flow_gw_join__end" sourceRef="gw_join" targetRef="end"/>
