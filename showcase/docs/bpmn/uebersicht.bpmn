      <bpmn:outgoing>flow_task_anfrage_und_dublettenpruefung__task_login_einladung</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_rechnungslauf" name="Rechnungslauf">
      <bpmn:incoming>flow_task_vertragsbestaetigung__task_rechnungslauf</bpmn:incoming>
      <bpmn:outgoing>flow_task_rechnungslauf__end</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="task_login_einladung" name="Login-Einladung">
