      <bpmn:outgoing>flow_task_ebz_bestaetigung__task_vertragsbestaetigung</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="flow_start__task_anfrage_und_dublettenpruefung" name="" sourceRef="start" targetRef="task_anfrage_und_dublettenpruefung" />
    <bpmn:sequenceFlow id="flow_task_ebz_bestaetigung__task_vertragsbestaetigung" name="" sourceRef="task_ebz_bestaetigung" targetRef="task_vertragsbestaetigung" />
    <bpmn:sequenceFlow id="flow_task_vertragsbestaetigung__task_rechnungslauf" name="" sourceRef="task_vertragsbestaetigung" targetRef="task_rechnungslauf" />
    <bpmn:sequenceFlow id="flow_task_rechnungslauf__end" name="" sourceRef="task_rechnungslauf" targetRef="end" />
    <bpmn:sequenceFlow id="flow_task_login_einladung__task_azubi_anmeldung" name="" sourceRef="task_login_einladung" targetRef="task_azubi_anmeldung" />
    <bpmn:sequenceFlow id="flow_task_azubi_anmeldung__task_ebz_bestaetigung" name="" sourceRef="task_azubi_anmeldung" targetRef="task_ebz_bestaetigung" />
    <bpmn:sequenceFlow id="flow_task_anfrage_und_dublettenpruefung__task_login_einladung" name="" sourceRef="task_anfrage_und_dublettenpruefung" targetRef="task_login_einladung" />
  </bpmn:process>
