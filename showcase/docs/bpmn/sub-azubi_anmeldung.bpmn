<?xml version="1.0" encoding="UTF-8"?>
<!-- swimlane-laidout: eigener Layouter (showcase/prozessdoku/generate.py) -->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://ebz/prozessdoku">
  <bpmn:collaboration id="collab_sub-azubi_anmeldung">
    <bpmn:participant id="participant_sub-azubi_anmeldung" name="Azubi-Anmeldung" processRef="process_sub-azubi_anmeldung"/>
  </bpmn:collaboration>
  <bpmn:process id="process_sub-azubi_anmeldung" isExecutable="false">
    <bpmn:laneSet id="laneset_sub-azubi_anmeldung">
      <bpmn:lane id="lane_sub-azubi_anmeldung_firma_ansprechpartner" name="Firma (Ansprechpartner)">
        <bpmn:flowNodeRef>start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_azubi_anmelden</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_sub-azubi_anmeldung_system" name="System">
        <bpmn:flowNodeRef>task_anmeldung_anlegen_angefragt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start" isInterrupting="true" name="start" parallelMultiple="false">
			<bpmn:outgoing>flow_start__task_azubi_anmelden</bpmn:outgoing>
		</bpmn:startEvent>
		<bpmn:task id="task_azubi_anmelden" name="Azubi anmelden · Portal-SPA">
			<bpmn:incoming>flow_start__task_azubi_anmelden</bpmn:incoming>
			<bpmn:outgoing>flow_task_azubi_anmelden__task_anmeldung_anlegen_angefragt</bpmn:outgoing>
		</bpmn:task>
		<bpmn:task id="task_anmeldung_anlegen_angefragt" name="Anmeldung anlegen (ANGEFRAGT) · integration-Backend">
			<bpmn:incoming>flow_task_azubi_anmelden__task_anmeldung_anlegen_angefragt</bpmn:incoming>
			<bpmn:outgoing>flow_task_anmeldung_anlegen_angefragt__end</bpmn:outgoing>
		</bpmn:task>
		<bpmn:endEvent id="end" name="end">
			<bpmn:incoming>flow_task_anmeldung_anlegen_angefragt__end</bpmn:incoming>
		</bpmn:endEvent>
		<bpmn:sequenceFlow id="flow_task_azubi_anmelden__task_anmeldung_anlegen_angefragt" name="" sourceRef="task_azubi_anmelden" targetRef="task_anmeldung_anlegen_angefragt"/>
		<bpmn:sequenceFlow id="flow_start__task_azubi_anmelden" name="" sourceRef="start" targetRef="task_azubi_anmelden"/>
		<bpmn:sequenceFlow id="flow_task_anmeldung_anlegen_angefragt__end" name="" sourceRef="task_anmeldung_anlegen_angefragt" targetRef="end"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="diagram_sub-azubi_anmeldung">
    <bpmndi:BPMNPlane id="plane_sub-azubi_anmeldung" bpmnElement="collab_sub-azubi_anmeldung">
      <bpmndi:BPMNShape id="participant_sub-azubi_anmeldung_di" bpmnElement="participant_sub-azubi_anmeldung" isHorizontal="true">
        <omgdc:Bounds x="0" y="0" width="780" height="220"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_sub-azubi_anmeldung_firma_ansprechpartner_di" bpmnElement="lane_sub-azubi_anmeldung_firma_ansprechpartner" isHorizontal="true">
        <omgdc:Bounds x="30" y="0" width="750" height="110"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_sub-azubi_anmeldung_system_di" bpmnElement="lane_sub-azubi_anmeldung_system" isHorizontal="true">
        <omgdc:Bounds x="30" y="110" width="750" height="110"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <omgdc:Bounds x="100" y="37" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_azubi_anmelden_di" bpmnElement="task_azubi_anmelden">
        <omgdc:Bounds x="280" y="15" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_anmeldung_anlegen_angefragt_di" bpmnElement="task_anmeldung_anlegen_angefragt">
        <omgdc:Bounds x="460" y="125" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_di" bpmnElement="end">
        <omgdc:Bounds x="640" y="147" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="flow_task_azubi_anmelden__task_anmeldung_anlegen_angefragt_di" bpmnElement="flow_task_azubi_anmelden__task_anmeldung_anlegen_angefragt">
        <omgdi:waypoint x="380" y="55"/>
        <omgdi:waypoint x="420" y="55"/>
        <omgdi:waypoint x="420" y="165"/>
        <omgdi:waypoint x="460" y="165"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_start__task_azubi_anmelden_di" bpmnElement="flow_start__task_azubi_anmelden">
        <omgdi:waypoint x="136" y="55"/>
        <omgdi:waypoint x="208" y="55"/>
        <omgdi:waypoint x="208" y="55"/>
        <omgdi:waypoint x="280" y="55"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_task_anmeldung_anlegen_angefragt__end_di" bpmnElement="flow_task_anmeldung_anlegen_angefragt__end">
        <omgdi:waypoint x="560" y="165"/>
        <omgdi:waypoint x="600" y="165"/>
        <omgdi:waypoint x="600" y="165"/>
        <omgdi:waypoint x="640" y="165"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
