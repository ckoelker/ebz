<?xml version="1.0" encoding="UTF-8"?>
<!-- swimlane-laidout: eigener Layouter (showcase/prozessdoku/generate.py) -->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://ebz/prozessdoku">
  <bpmn:collaboration id="collab_sub-vertrag">
    <bpmn:participant id="participant_sub-vertrag" name="Vertragsbestätigung" processRef="process_sub-vertrag"/>
  </bpmn:collaboration>
  <bpmn:process id="process_sub-vertrag" isExecutable="false">
    <bpmn:laneSet id="laneset_sub-vertrag">
      <bpmn:lane id="lane_sub-vertrag_firma_ansprechpartner" name="Firma (Ansprechpartner)">
        <bpmn:flowNodeRef>end</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_ausbildungsvertrag_bestaetigen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>start</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:endEvent id="end" name="end">
			<bpmn:incoming>flow_task_ausbildungsvertrag_bestaetigen__end</bpmn:incoming>
		</bpmn:endEvent>
		<bpmn:task id="task_ausbildungsvertrag_bestaetigen" name="Ausbildungsvertrag bestätigen · Portal-SPA">
			<bpmn:incoming>flow_start__task_ausbildungsvertrag_bestaetigen</bpmn:incoming>
			<bpmn:outgoing>flow_task_ausbildungsvertrag_bestaetigen__end</bpmn:outgoing>
		</bpmn:task>
		<bpmn:startEvent id="start" isInterrupting="true" name="start" parallelMultiple="false">
			<bpmn:outgoing>flow_start__task_ausbildungsvertrag_bestaetigen</bpmn:outgoing>
		</bpmn:startEvent>
		<bpmn:sequenceFlow id="flow_start__task_ausbildungsvertrag_bestaetigen" name="" sourceRef="start" targetRef="task_ausbildungsvertrag_bestaetigen"/>
		<bpmn:sequenceFlow id="flow_task_ausbildungsvertrag_bestaetigen__end" name="" sourceRef="task_ausbildungsvertrag_bestaetigen" targetRef="end"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="diagram_sub-vertrag">
    <bpmndi:BPMNPlane id="plane_sub-vertrag" bpmnElement="collab_sub-vertrag">
      <bpmndi:BPMNShape id="participant_sub-vertrag_di" bpmnElement="participant_sub-vertrag" isHorizontal="true">
        <omgdc:Bounds x="0" y="0" width="600" height="110"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_sub-vertrag_firma_ansprechpartner_di" bpmnElement="lane_sub-vertrag_firma_ansprechpartner" isHorizontal="true">
        <omgdc:Bounds x="30" y="0" width="570" height="110"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_di" bpmnElement="end">
        <omgdc:Bounds x="460" y="37" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_ausbildungsvertrag_bestaetigen_di" bpmnElement="task_ausbildungsvertrag_bestaetigen">
        <omgdc:Bounds x="280" y="15" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <omgdc:Bounds x="100" y="37" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="flow_start__task_ausbildungsvertrag_bestaetigen_di" bpmnElement="flow_start__task_ausbildungsvertrag_bestaetigen">
        <omgdi:waypoint x="136" y="55"/>
        <omgdi:waypoint x="208" y="55"/>
        <omgdi:waypoint x="208" y="55"/>
        <omgdi:waypoint x="280" y="55"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_task_ausbildungsvertrag_bestaetigen__end_di" bpmnElement="flow_task_ausbildungsvertrag_bestaetigen__end">
        <omgdi:waypoint x="380" y="55"/>
        <omgdi:waypoint x="420" y="55"/>
        <omgdi:waypoint x="420" y="55"/>
        <omgdi:waypoint x="460" y="55"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
