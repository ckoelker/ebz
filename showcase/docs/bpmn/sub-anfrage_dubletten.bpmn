<?xml version="1.0" encoding="UTF-8"?>
<!-- swimlane-laidout: eigener Layouter (showcase/prozessdoku/generate.py) -->
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://ebz/prozessdoku">
  <bpmn:collaboration id="collab_sub-anfrage_dubletten">
    <bpmn:participant id="participant_sub-anfrage_dubletten" name="Anfrage &amp; Dublettenprüfung" processRef="process_sub-anfrage_dubletten"/>
  </bpmn:collaboration>
  <bpmn:process id="process_sub-anfrage_dubletten" isExecutable="false">
    <bpmn:laneSet id="laneset_sub-anfrage_dubletten">
      <bpmn:lane id="lane_sub-anfrage_dubletten_interessent_anonym" name="Interessent (anonym)">
        <bpmn:flowNodeRef>start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>exclusivegateway_x_2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_ausbildungsbetrieb_anfrage_stellen</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_sub-anfrage_dubletten_ebz_sachbearbeitung" name="EBZ-Sachbearbeitung">
        <bpmn:flowNodeRef>end</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>exclusivegateway_x</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_dubletten_merge_bestaetigen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>task_neuanlage_bestaetigen</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_sub-anfrage_dubletten_system" name="System">
        <bpmn:flowNodeRef>task_ki_dublettenbewertung</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start" isInterrupting="true" name="start" parallelMultiple="false">
			<bpmn:outgoing>flow_start__task_ausbildungsbetrieb_anfrage_stellen</bpmn:outgoing>
		</bpmn:startEvent>
		<bpmn:endEvent id="end" name="end">
			<bpmn:incoming>flow_exclusivegateway_x__end</bpmn:incoming>
		</bpmn:endEvent>
		<bpmn:exclusiveGateway id="exclusivegateway_x" gatewayDirection="Converging" name="">
			<bpmn:incoming>flow_task_neuanlage_bestaetigen__exclusivegateway_x</bpmn:incoming>
			<bpmn:incoming>flow_task_dubletten_merge_bestaetigen__exclusivegateway_x</bpmn:incoming>
			<bpmn:outgoing>flow_exclusivegateway_x__end</bpmn:outgoing>
		</bpmn:exclusiveGateway>
		<bpmn:task id="task_ki_dublettenbewertung" name="KI-Dublettenbewertung · integration-Backend">
			<bpmn:incoming>flow_exclusivegateway_x_2__task_ki_dublettenbewertung</bpmn:incoming>
			<bpmn:outgoing>flow_task_ki_dublettenbewertung__task_dubletten_merge_bestaetigen</bpmn:outgoing>
		</bpmn:task>
		<bpmn:exclusiveGateway id="exclusivegateway_x_2" gatewayDirection="Diverging" name="">
			<bpmn:incoming>flow_task_ausbildungsbetrieb_anfrage_stellen__exclusivegateway_x_2</bpmn:incoming>
			<bpmn:outgoing>flow_exclusivegateway_x_2__task_neuanlage_bestaetigen</bpmn:outgoing>
			<bpmn:outgoing>flow_exclusivegateway_x_2__task_ki_dublettenbewertung</bpmn:outgoing>
		</bpmn:exclusiveGateway>
		<bpmn:task id="task_ausbildungsbetrieb_anfrage_stellen" name="Ausbildungsbetrieb-Anfrage stellen · Portal-SPA">
			<bpmn:incoming>flow_start__task_ausbildungsbetrieb_anfrage_stellen</bpmn:incoming>
			<bpmn:outgoing>flow_task_ausbildungsbetrieb_anfrage_stellen__exclusivegateway_x_2</bpmn:outgoing>
		</bpmn:task>
		<bpmn:task id="task_dubletten_merge_bestaetigen" name="Dubletten-Merge bestätigen · MDM-Cockpit">
			<bpmn:incoming>flow_task_ki_dublettenbewertung__task_dubletten_merge_bestaetigen</bpmn:incoming>
			<bpmn:outgoing>flow_task_dubletten_merge_bestaetigen__exclusivegateway_x</bpmn:outgoing>
		</bpmn:task>
		<bpmn:task id="task_neuanlage_bestaetigen" name="Neuanlage bestätigen · MDM-Cockpit">
			<bpmn:incoming>flow_exclusivegateway_x_2__task_neuanlage_bestaetigen</bpmn:incoming>
			<bpmn:outgoing>flow_task_neuanlage_bestaetigen__exclusivegateway_x</bpmn:outgoing>
		</bpmn:task>
		<bpmn:sequenceFlow id="flow_exclusivegateway_x_2__task_ki_dublettenbewertung" name="" sourceRef="exclusivegateway_x_2" targetRef="task_ki_dublettenbewertung"/>
		<bpmn:sequenceFlow id="flow_task_dubletten_merge_bestaetigen__exclusivegateway_x" name="" sourceRef="task_dubletten_merge_bestaetigen" targetRef="exclusivegateway_x"/>
		<bpmn:sequenceFlow id="flow_exclusivegateway_x__end" name="" sourceRef="exclusivegateway_x" targetRef="end"/>
		<bpmn:sequenceFlow id="flow_task_ki_dublettenbewertung__task_dubletten_merge_bestaetigen" name="" sourceRef="task_ki_dublettenbewertung" targetRef="task_dubletten_merge_bestaetigen"/>
		<bpmn:sequenceFlow id="flow_task_neuanlage_bestaetigen__exclusivegateway_x" name="" sourceRef="task_neuanlage_bestaetigen" targetRef="exclusivegateway_x"/>
		<bpmn:sequenceFlow id="flow_exclusivegateway_x_2__task_neuanlage_bestaetigen" name="" sourceRef="exclusivegateway_x_2" targetRef="task_neuanlage_bestaetigen"/>
		<bpmn:sequenceFlow id="flow_task_ausbildungsbetrieb_anfrage_stellen__exclusivegateway_x_2" name="" sourceRef="task_ausbildungsbetrieb_anfrage_stellen" targetRef="exclusivegateway_x_2"/>
		<bpmn:sequenceFlow id="flow_start__task_ausbildungsbetrieb_anfrage_stellen" name="" sourceRef="start" targetRef="task_ausbildungsbetrieb_anfrage_stellen"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="diagram_sub-anfrage_dubletten">
    <bpmndi:BPMNPlane id="plane_sub-anfrage_dubletten" bpmnElement="collab_sub-anfrage_dubletten">
      <bpmndi:BPMNShape id="participant_sub-anfrage_dubletten_di" bpmnElement="participant_sub-anfrage_dubletten" isHorizontal="true">
        <omgdc:Bounds x="0" y="0" width="1320" height="330"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_sub-anfrage_dubletten_interessent_anonym_di" bpmnElement="lane_sub-anfrage_dubletten_interessent_anonym" isHorizontal="true">
        <omgdc:Bounds x="30" y="0" width="1290" height="110"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_sub-anfrage_dubletten_ebz_sachbearbeitung_di" bpmnElement="lane_sub-anfrage_dubletten_ebz_sachbearbeitung" isHorizontal="true">
        <omgdc:Bounds x="30" y="110" width="1290" height="110"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="lane_sub-anfrage_dubletten_system_di" bpmnElement="lane_sub-anfrage_dubletten_system" isHorizontal="true">
        <omgdc:Bounds x="30" y="220" width="1290" height="110"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
