      <bpmndi:BPMNEdge id="flow_exclusivegateway_x_2__task_neuanlage_bestaetigen_di" bpmnElement="flow_exclusivegateway_x_2__task_neuanlage_bestaetigen">
        <omgdi:waypoint x="510" y="55"/>
        <omgdi:waypoint x="575" y="55"/>
