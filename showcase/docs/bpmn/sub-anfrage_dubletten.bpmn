      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_di" bpmnElement="end">
        <omgdc:Bounds x="1180" y="147" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="exclusivegateway_x_di" bpmnElement="exclusivegateway_x">
        <omgdc:Bounds x="1000" y="140" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_ki_dublettenbewertung_di" bpmnElement="task_ki_dublettenbewertung">
        <omgdc:Bounds x="640" y="235" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="exclusivegateway_x_2_di" bpmnElement="exclusivegateway_x_2">
        <omgdc:Bounds x="460" y="30" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_ausbildungsbetrieb_anfrage_stellen_di" bpmnElement="task_ausbildungsbetrieb_anfrage_stellen">
        <omgdc:Bounds x="280" y="15" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_dubletten_merge_bestaetigen_di" bpmnElement="task_dubletten_merge_bestaetigen">
        <omgdc:Bounds x="820" y="125" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="task_neuanlage_bestaetigen_di" bpmnElement="task_neuanlage_bestaetigen">
        <omgdc:Bounds x="640" y="125" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="flow_exclusivegateway_x_2__task_ki_dublettenbewertung_di" bpmnElement="flow_exclusivegateway_x_2__task_ki_dublettenbewertung">
        <omgdi:waypoint x="510" y="55"/>
        <omgdi:waypoint x="575" y="55"/>
        <omgdi:waypoint x="575" y="275"/>
        <omgdi:waypoint x="640" y="275"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_task_dubletten_merge_bestaetigen__exclusivegateway_x_di" bpmnElement="flow_task_dubletten_merge_bestaetigen__exclusivegateway_x">
        <omgdi:waypoint x="920" y="165"/>
        <omgdi:waypoint x="960" y="165"/>
        <omgdi:waypoint x="960" y="165"/>
        <omgdi:waypoint x="1000" y="165"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_exclusivegateway_x__end_di" bpmnElement="flow_exclusivegateway_x__end">
        <omgdi:waypoint x="1050" y="165"/>
        <omgdi:waypoint x="1115" y="165"/>
        <omgdi:waypoint x="1115" y="165"/>
        <omgdi:waypoint x="1180" y="165"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_task_ki_dublettenbewertung__task_dubletten_merge_bestaetigen_di" bpmnElement="flow_task_ki_dublettenbewertung__task_dubletten_merge_bestaetigen">
        <omgdi:waypoint x="740" y="275"/>
        <omgdi:waypoint x="780" y="275"/>
        <omgdi:waypoint x="780" y="165"/>
        <omgdi:waypoint x="820" y="165"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_task_neuanlage_bestaetigen__exclusivegateway_x_di" bpmnElement="flow_task_neuanlage_bestaetigen__exclusivegateway_x">
        <omgdi:waypoint x="740" y="165"/>
        <omgdi:waypoint x="870" y="165"/>
        <omgdi:waypoint x="870" y="165"/>
        <omgdi:waypoint x="1000" y="165"/>
