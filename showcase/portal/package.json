{
  "name": "ebz-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "description": "EBZ Außenportal — Self-Service für Firmen & Teilnehmer (Realm ebz-customers). Vue 3 gegen den Quarkus-integration-Service; typsicher generiert aus /q/openapi (Stack B). Shop bleibt eigenständig.",
  "scripts": {
    "dev": "vite",
