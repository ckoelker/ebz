    "typecheck": "vue-tsc --noEmit",
    "gen": "orval",
    "test": "vitest run"
  },
  "dependencies": {
    "@nuxt/ui": "4.8.2",
    "@tanstack/vue-query": "5.101.0",
    "@tanstack/vue-table": "8.21.3",
    "@vee-validate/zod": "4.15.1",
    "axios": "^1.18.0",
    "oidc-client-ts": "3.5.0",
    "pinia": "3.0.4",
    "tailwindcss": "4.3.1",
    "vee-validate": "4.15.1",
    "vue": "3.5.38",
    "vue-router": "5.1.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "@vitejs/plugin-vue": "6.0.7",
    "orval": "^8.17.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8",
    "vue-tsc": "3.3.4"
  }
