# showcase/.env.example — Vorlage. Kopieren nach showcase/.env und Werte anpassen.
# Compose liest showcase/.env automatisch; alle Variablen haben in der Compose
# Defaults, d. h. der Stack läuft auch ohne .env mit genau diesen Werten.

# ── Postgres (EIN Container = Single Source of Truth) ──
POSTGRES_USER=vendure
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vendure
POSTGRES_PORT=6543

# Controlling-Warehouse — eigene DB + eigener Owner-User
CONTROLLING_DB=controlling
CONTROLLING_USER=controlling
CONTROLLING_PASSWORD=change-me

# Lightdash-Metadaten — eigene DB + eigener User
LIGHTDASH_DB=lightdash
LIGHTDASH_USER=lightdash
LIGHTDASH_PASSWORD=change-me

# Read-only-User für dlt auf der Shop-DB `vendure` (L20: Quelle nur lesen)
READER_USER=controlling_reader
READER_PASSWORD=change-me

# ── Vendure (Shop) ──
VENDURE_PORT=3000
COOKIE_SECRET=change-me
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me

# ── Keycloak ── (bei Änderung von KEYCLOAK_PORT auch frontend/.env.development anpassen)
KEYCLOAK_PORT=8088
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# ── Adminer ──
ADMINER_PORT=8082

# ── Controlling-Ingestion (M1) ──
HUBSPOT_TOKEN=
# KI-Anreicherung via OpenAI (AVV/DPA vorhanden). Ohne Key → regelbasierter Fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
