# showcase/.env.example — Vorlage. Kopieren nach showcase/.env und Werte anpassen.
# Compose liest showcase/.env automatisch; alle Variablen haben in der Compose
# Defaults, d. h. der Stack läuft auch ohne .env mit genau diesen Werten.

# ── Postgres (EIN Container = Single Source of Truth) ──
POSTGRES_USER=vendure
POSTGRES_PASSWORD=change-me
POSTGRES_DB=vendure
POSTGRES_PORT=6543

# Controlling-Warehouse — eigene DB + eigener Owner-User
CONTROLLING_DB=controlling
CONTROLLING_USER=controlling
CONTROLLING_PASSWORD=change-me

# Lightdash-Metadaten — eigene DB + eigener User
LIGHTDASH_DB=lightdash
LIGHTDASH_USER=lightdash
LIGHTDASH_PASSWORD=change-me

# Read-only-User für dlt auf der Shop-DB `vendure` (L20: Quelle nur lesen)
READER_USER=controlling_reader
READER_PASSWORD=change-me

# ── Vendure (Shop) ──
VENDURE_PORT=3000
COOKIE_SECRET=change-me
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me

# ── Keycloak ── (bei Änderung von KEYCLOAK_PORT auch frontend/.env.development anpassen)
KEYCLOAK_PORT=8088
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# ── Adminer ──
ADMINER_PORT=8082

# ── Controlling-Ingestion (M1) ──
# Quelle: leer/ungesetzt → Fixture-Mock (Default). Real-Modus: INGESTION_SOURCE=hubspot.
INGESTION_SOURCE=fixture
# HubSpot-Bearer-Token (CRM v3, Scope crm.objects.deals.read). KEIN Entwickler-API-Key!
# Empfohlen: Account Service Key (Developer-Plattform 2026.03, Public Beta) — statisches
#   pat-na1-… Token: HubSpot → Development → Keys → Service keys → Create service key.
# Fallback: Legacy Private App (Development → Legacy apps → Private). Details: integration/README.md.
HUBSPOT_TOKEN=
# L6-Filter: Pipeline-ID der Inhouse-Deals. HubSpot-Default-Pipeline = `default`
# (Label „Sales Pipeline"); Fixture-Mock nutzt `inhouse`. Für Real-Modus i. d. R. `default`.
HUBSPOT_INHOUSE_PIPELINE=default
# KI-Anreicherung via OpenAI (AVV/DPA vorhanden). Ohne Key → regelbasierter Fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Lightdash (M4, Profil controlling) ──
LIGHTDASH_PORT=8084
# Verschlüsselt Daten at-rest in der Lightdash-DB — zwischen Deployments fix halten.
LIGHTDASH_SECRET=lightdash-dev-secret-change-me
# Muss dem Client-Secret des Keycloak-Clients `lightdash` (ebz-staff-Realm) entsprechen.
LIGHTDASH_OIDC_SECRET=lightdash-dev-secret
# L21: erst false (Bootstrap-Admin via SSO), nach erstem SSO-Login auf true (SSO-Zwang).
LIGHTDASH_DISABLE_PW=false

# ── MinIO (S3-kompatibler Objektspeicher; Lightdash 0.3059 erzwingt S3) ──
# Self-host S3 für Lightdash Pre-Aggregate-Results. Nur S3-API (:9000) nötig.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_API_PORT=9000
LIGHTDASH_S3_BUCKET=lightdash
S3_REGION=us-east-1
